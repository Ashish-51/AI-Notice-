rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isTeacher() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'teacher';
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.role in ['teacher', 'student'] &&
             data.institution is string && data.institution.size() <= 200 &&
             data.department is string && data.department.size() <= 200 &&
             (data.role == 'student' || (data.role == 'teacher' && data.staffId is string && data.staffId.size() <= 50)) &&
             data.createdAt == request.time;
    }

    function isValidNotice(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 10000 &&
             data.summary is string && data.summary.size() <= 2000 &&
             data.simplified is string && data.simplified.size() <= 5000 &&
             data.category in ['Exam', 'Event', 'Placement', 'Assignment', 'Other'] &&
             data.priority in ['Normal', 'Important', 'Urgent'] &&
             data.expiryDate is timestamp &&
             data.updatedAt == request.time &&
             data.authorId == request.auth.uid &&
             data.authorName is string && data.authorName.size() <= 100 &&
             data.isPinned is bool &&
             data.formLink is string && data.formLink.size() <= 500 &&
             data.viewCount is int && data.viewCount >= 0;
    }

    // --- Collections ---

    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isTeacher()); // Teachers can see students, users see themselves
      
      allow create: if isOwner(userId) && 
                    isValidUser(incoming()) && 
                    incoming().keys().hasAll(['uid', 'email', 'displayName', 'role', 'institution', 'department', 'createdAt']) &&
                    (incoming().role == 'student' ? incoming().keys().size() == 7 : incoming().keys().size() == 8);
      
      allow update: if isOwner(userId) && 
                    isValidUser(incoming()) && 
                    incoming().uid == existing().uid &&
                    incoming().email == existing().email &&
                    incoming().role == existing().role &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'department', 'institution', 'staffId']);
    }

    match /notices/{noticeId} {
      allow read: if isSignedIn();
      
      allow create: if isTeacher() && 
                    isValidNotice(incoming()) && 
                    incoming().createdAt == request.time &&
                    incoming().viewCount == 0;
      
      allow update: if (isTeacher() && existing().authorId == request.auth.uid && isValidNotice(incoming()) && incoming().authorId == existing().authorId && incoming().createdAt == existing().createdAt) ||
                    (isSignedIn() && 
                     incoming().diff(existing()).affectedKeys().hasOnly(['viewCount']) &&
                     incoming().viewCount == existing().viewCount + 1 &&
                     incoming().title == existing().title &&
                     incoming().description == existing().description); // Public can increment viewCount
      
      allow delete: if isTeacher() && existing().authorId == request.auth.uid;
    }
  }
}
