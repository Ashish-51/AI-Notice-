{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with role-based access control information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher", "student"] },
        "institution": { "type": "string" },
        "department": { "type": "string" },
        "staffId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "institution", "department"]
    },
    "Notice": {
      "title": "Smart Notice",
      "description": "A notice published by a teacher with AI-enhanced content.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "summary": { "type": "string" },
        "simplified": { "type": "string" },
        "category": { "type": "string", "enum": ["Assignment", "Event", "Exam", "Workshop", "Holiday", "Placement", "Urgent", "Circular", "Competition", "Seminar", "Club Activity", "Other"] },
        "priority": { "type": "string", "enum": ["Normal", "Important", "Urgent"] },
        "expiryDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "isPinned": { "type": "boolean" },
        "attachmentUrl": { "type": "string" },
        "attachmentName": { "type": "string" },
        "attachmentType": { "type": "string" },
        "formLink": { "type": "string" },
        "viewCount": { "type": "number" }
      },
      "required": ["title", "description", "category", "priority", "expiryDate", "authorId"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles."
    },
    "notices/{noticeId}": {
      "schema": "Notice",
      "description": "Stores notices."
    }
  }
}
