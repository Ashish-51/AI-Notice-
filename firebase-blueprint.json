{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information including role and academic details.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher"] },
        "institution": { "type": "string" },
        "department": { "type": "string" },
        "semester": { "type": "string" },
        "staffId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Notice": {
      "title": "Notice",
      "description": "Represents a university notice or announcement.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["Academics", "Events & Activities", "Career & Placements", "Holidays & Leave", "General"] },
        "audienceType": { "type": "string", "enum": ["Everyone", "Entire Faculty", "Specific Course", "Specific Semester"] },
        "faculty": { "type": "string" },
        "department": { "type": "string" },
        "semester": { "type": "string" },
        "priority": { "type": "string", "enum": ["Normal", "Important", "Urgent"] },
        "attachmentUrl": { "type": "string" },
        "attachmentName": { "type": "string" },
        "attachmentType": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "uploaderRole": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "viewCount": { "type": "number" },
        "isPinned": { "type": "boolean" }
      },
      "required": ["title", "description", "category", "audienceType", "faculty", "authorId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/notices/{noticeId}": {
      "schema": "Notice",
      "description": "Collection of all university notices."
    }
  }
}
