rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(role) {
      let profileDoc = getProfile();
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (profileDoc.get('data', {}).get('role', 'none') == role || profileDoc.get('data', {}).get('role', 'none') == 'admin');
    }

    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'none') == 'admin')) ||
        request.auth.token.email.matches('.*@paruluniversity\\.ac\\.in$')
      );
    }

    function isTeacher() {
      return hasRole('teacher');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Notice Validation
    function isValidNotice(data) {
      return data.get('title', '') is string && data.title.size() > 0
          && data.get('description', '') is string && data.description.size() > 0
          && (data.get('authorId', '') == request.auth.uid || isAdmin())
          && (data.get('updatedAt', request.time) == request.time);
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // 2. Notices Collection
    match /notices/{noticeId} {
      allow get, list: if isSignedIn();

      allow create: if isSignedIn() 
                    && (isTeacher() || isAdmin() || request.auth.token.email.matches('.*@paruluniversity\\.ac\\.in$'))
                    && isValidNotice(request.resource.data);

      allow update: if isSignedIn() && (
        // Action: Increment Views
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])) ||
        // Action: Edit (Author or Admin)
        (
          (resource.data.authorId == request.auth.uid || isAdmin()) &&
          isValidNotice(request.resource.data)
        )
      );

      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
    }
  }
}
