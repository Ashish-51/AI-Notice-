rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function existingData() {
      return resource.data;
    }

    function incomingData() {
      return request.resource.data;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getProfile().institution == 'Parul University';
    }

    function isTeacher() {
      return isSignedIn() && getProfile().role == 'teacher';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Notice Validation
    function isValidNotice(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200
          && data.description is string && data.description.size() > 0 && data.description.size() <= 5000
          && data.category in ['Academics', 'Events & Activities', 'Career & Placements', 'Holidays & Leave', 'General']
          && data.audienceType in ['Everyone', 'Entire Faculty', 'Specific Course', 'Specific Semester']
          && (data.faculty is string || data.faculty == null)
          && data.priority in ['Normal', 'Important', 'Urgent']
          && (data.authorId == request.auth.uid || isAdmin())
          && (data.uploadedBy == request.auth.uid || isAdmin())
          && (data.attachmentUrl is string || data.attachmentUrl == null)
          && (data.attachmentName is string || data.attachmentName == null)
          && (data.attachmentType is string || data.attachmentType == null)
          && (data.visibilityScope is string || data.visibilityScope == null)
          && (data.viewCount is number)
          && (data.isPinned is bool)
          && data.createdAt == request.time
          && data.updatedAt == request.time;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin())
                    && incomingData().diff(existingData()).affectedKeys().hasOnly(['displayName', 'institution', 'department', 'semester', 'staffId', 'faculty', 'role']);
    }

    // 2. Notices Collection
    match /notices/{noticeId} {
      allow get: if isSignedIn();
      
      // We allow authenticated listing to support complex composite queries (e.g. using or()).
      // Security is maintained via specific client-side queries and individual document read/write authorization.
      allow list: if isSignedIn();

      allow create: if isSignedIn() && (isTeacher() || isAdmin()) && isValidNotice(incomingData()) && (
        isAdmin() || incomingData().faculty == getProfile().institution
      );

      allow update: if isSignedIn() && (
        (existingData().authorId == request.auth.uid && isValidNotice(incomingData())) || 
        isAdmin()
      ) && incomingData().diff(existingData()).affectedKeys().hasOnly(['viewCount', 'title', 'description', 'category', 'audienceType', 'department', 'semester', 'priority', 'attachmentUrl', 'attachmentName', 'attachmentType', 'updatedAt', 'isPinned']);

      allow delete: if isSignedIn() && (existingData().authorId == request.auth.uid || isAdmin());
    }
  }
}
