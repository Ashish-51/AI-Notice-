rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isTeacher() {
      return isSignedIn() && getUserData().role == 'teacher';
    }

    function isStudent() {
      return isSignedIn() && getUserData().role == 'student';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation helpers
    function isValidNotice(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.description is string && data.description.size() > 0 &&
             data.category in ['Exam', 'Event', 'Placement', 'Assignment', 'Other'] &&
             data.priority in ['Normal', 'Important', 'Urgent'] &&
             data.expiryDate is timestamp &&
             data.authorId == request.auth.uid;
    }

    // Collections
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    request.resource.data.role in ['teacher', 'student'] &&
                    request.resource.data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
                    request.resource.data.keys().size() == 5;
      allow update: if isSignedIn() && request.auth.uid == userId &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName']);
    }

    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow create: if isTeacher() && isValidNotice(request.resource.data) &&
                    request.resource.data.createdAt == request.time;
      allow update: if (isTeacher() && resource.data.authorId == request.auth.uid && isValidNotice(request.resource.data)) ||
                    (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']));
      allow delete: if isTeacher() && resource.data.authorId == request.auth.uid;
    }
  }
}
